{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LauncherKernelContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "kernel_id",
    "language",
    "argv",
    "runtime_id",
    "runtime_receipt_path",
    "bootstrap_argv"
  ],
  "properties": {
    "contract_version": { "type": "string" },
    "kernel_id": { "type": "string" },
    "display_name": { "type": "string" },
    "language": { "type": "string" },
    "argv": {
      "type": "array",
      "items": { "type": "string" }
    },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "runtime_id": { "type": "string" },
    "runtime_receipt_path": { "type": "string" },
    "launcher_path": { "type": "string" },
    "bootstrap_argv": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
